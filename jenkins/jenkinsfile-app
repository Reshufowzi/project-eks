pipeline {
  agent any

  environment {
    AWS_REGION = "ap-south-1"
    DOCKERHUB_USERNAME = "your-dockerhub-username"
    IMAGE_NAME = "devops-app"
    BUILD_TAG = "${BUILD_NUMBER}"
  }

  stages {

    stage('Get Cluster Name from SSM') {
      steps {
        script {
          CLUSTER_NAME = sh(
            script: "aws ssm get-parameter --name /eks/cluster_name --query Parameter.Value --output text",
            returnStdout: true
          ).trim()
        }
      }
    }

    stage('Build App') {
      steps {
        dir('app') {
          sh 'mvn clean package'
        }
      }
    }

    stage('Build Docker Image') {
      steps {
        dir('app') {
          sh """
          docker build -t $DOCKERHUB_USERNAME/$IMAGE_NAME:$BUILD_TAG .
          docker build -t $DOCKERHUB_USERNAME/$IMAGE_NAME:latest .
          """
        }
      }
    }

    stage('Push Docker Image') {
      steps {
        sh """
        docker push $DOCKERHUB_USERNAME/$IMAGE_NAME:$BUILD_TAG
        docker push $DOCKERHUB_USERNAME/$IMAGE_NAME:latest
        """
      }
    }

    stage('Deploy to EKS') {
      steps {
        sh "aws eks update-kubeconfig --region $AWS_REGION --name $CLUSTER_NAME"

        dir('app/k8s') {
          sh """
          sed -i 's|IMAGE_TAG|$BUILD_TAG|g' deployment.yaml
          kubectl apply -f deployment.yaml
          kubectl apply -f service.yaml
          """
        }
      }
    }
  }
}
